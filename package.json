{
  "name": "copilot-debugger",
  "displayName": "Copilot Debugger",
  "description": "Exposes Python debug state to AI coding agents (Copilot, Claude Code) via debug tools",
  "version": "0.1.0",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/gziz/vs-copilot-debugger.git"
  },
  "icon": "images/debugger_icon.png",
  "publisher": "gziz",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "enabledApiProposals": [],
  "contributes": {
    "languageModelTools": [
      {
        "name": "debug_start_session",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "startDebug",
        "displayName": "Start Debug Session",
        "modelDescription": "Start a new Python debug session for the specified script. Returns session info with initialStop field.",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-start)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "script": {
              "type": "string",
              "description": "Path to the Python script to debug"
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Command-line arguments"
            },
            "cwd": {
              "type": "string",
              "description": "Working directory"
            },
            "stopOnEntry": {
              "type": "boolean",
              "description": "Stop on first line (default: true)"
            },
            "justMyCode": {
              "type": "boolean",
              "description": "Debug only user code (default: true)"
            },
            "pythonPath": {
              "type": "string",
              "description": "Path to Python executable"
            },
            "name": {
              "type": "string",
              "description": "Session name"
            }
          },
          "required": [
            "script"
          ]
        }
      },
      {
        "name": "debug_stop_session",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "stopDebug",
        "displayName": "Stop Debug Session",
        "modelDescription": "Stop an active debug session",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-stop)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Session ID to stop"
            }
          },
          "required": [
            "sessionId"
          ]
        }
      },
      {
        "name": "debug_list_sessions",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "listDebugSessions",
        "displayName": "List Debug Sessions",
        "modelDescription": "List all active debug sessions with their IDs and status",
        "canBeReferencedInPrompt": true,
        "icon": "$(list-unordered)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "debug_attach",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "attachDebug",
        "displayName": "Attach to Debug Session",
        "modelDescription": "Attach to a running debugpy process",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-start)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "host": {
              "type": "string",
              "description": "Host (default: localhost)"
            },
            "port": {
              "type": "number",
              "description": "Port to connect to"
            },
            "name": {
              "type": "string",
              "description": "Session name"
            }
          },
          "required": [
            "port"
          ]
        }
      },
      {
        "name": "debug_set_breakpoint_by_text",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "setBreakpointByText",
        "displayName": "Set Breakpoint by Text",
        "modelDescription": "Set a breakpoint by matching exact line text in a file. Use occurrence param if multiple lines match.",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-breakpoint)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "description": "Path to the source file"
            },
            "lineText": {
              "type": "string",
              "description": "Exact text of the line (whitespace trimmed)"
            },
            "occurrence": {
              "type": "number",
              "description": "Which occurrence (1-indexed) if multiple match"
            },
            "condition": {
              "type": "string",
              "description": "Condition expression"
            },
            "hitCondition": {
              "type": "string",
              "description": "Hit count condition"
            },
            "logMessage": {
              "type": "string",
              "description": "Log message (logpoint)"
            }
          },
          "required": [
            "file",
            "lineText"
          ]
        }
      },
      {
        "name": "debug_remove_breakpoint",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "removeBreakpoint",
        "displayName": "Remove Breakpoint",
        "modelDescription": "Remove a breakpoint by its ID",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-breakpoint-disabled)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "breakpointId": {
              "type": "string",
              "description": "Breakpoint ID to remove"
            }
          },
          "required": [
            "breakpointId"
          ]
        }
      },
      {
        "name": "debug_list_breakpoints",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "listBreakpoints",
        "displayName": "List Breakpoints",
        "modelDescription": "List all breakpoints",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-breakpoint)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "debug_continue",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "continueDebug",
        "displayName": "Continue Execution",
        "modelDescription": "Continue execution until next breakpoint or program end",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-continue)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "threadId": {
              "type": "number",
              "description": "Thread ID (optional)"
            }
          },
          "required": [
            "sessionId"
          ]
        }
      },
      {
        "name": "debug_pause",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "pauseDebug",
        "displayName": "Pause Execution",
        "modelDescription": "Pause execution of the debugged program",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-pause)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "threadId": {
              "type": "number",
              "description": "Thread ID (optional)"
            }
          },
          "required": [
            "sessionId"
          ]
        }
      },
      {
        "name": "debug_step_into",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "stepInto",
        "displayName": "Step Into",
        "modelDescription": "Step into a function call",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-step-into)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "threadId": {
              "type": "number",
              "description": "Thread ID (optional)"
            }
          },
          "required": [
            "sessionId"
          ]
        }
      },
      {
        "name": "debug_step_over",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "stepOver",
        "displayName": "Step Over",
        "modelDescription": "Step over the current line",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-step-over)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "threadId": {
              "type": "number",
              "description": "Thread ID (optional)"
            }
          },
          "required": [
            "sessionId"
          ]
        }
      },
      {
        "name": "debug_step_out",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "stepOut",
        "displayName": "Step Out",
        "modelDescription": "Step out of the current function",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-step-out)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "threadId": {
              "type": "number",
              "description": "Thread ID (optional)"
            }
          },
          "required": [
            "sessionId"
          ]
        }
      },
      {
        "name": "debug_get_threads",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "getThreads",
        "displayName": "Get Threads",
        "modelDescription": "Get all threads and their states in the debug session",
        "canBeReferencedInPrompt": true,
        "icon": "$(list-tree)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            }
          },
          "required": [
            "sessionId"
          ]
        }
      },
      {
        "name": "debug_get_stack_trace",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "getStackTrace",
        "displayName": "Get Stack Trace",
        "modelDescription": "Get the call stack for a thread",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-stackframe)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "threadId": {
              "type": "number",
              "description": "Thread ID (optional)"
            },
            "startFrame": {
              "type": "number",
              "description": "Start frame index"
            },
            "levels": {
              "type": "number",
              "description": "Number of frames to retrieve"
            }
          },
          "required": [
            "sessionId"
          ]
        }
      },
      {
        "name": "debug_get_scopes",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "getScopes",
        "displayName": "Get Scopes",
        "modelDescription": "Get variable scopes (locals, globals) for a stack frame",
        "canBeReferencedInPrompt": true,
        "icon": "$(symbol-namespace)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "frameId": {
              "type": "number",
              "description": "Stack frame ID from get_stack_trace"
            }
          },
          "required": [
            "sessionId",
            "frameId"
          ]
        }
      },
      {
        "name": "debug_get_variables",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "getVariables",
        "displayName": "Get Variables",
        "modelDescription": "Get variable names, types, and values in a scope",
        "canBeReferencedInPrompt": true,
        "icon": "$(symbol-variable)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "variablesReference": {
              "type": "number",
              "description": "Variables reference from scope or variable"
            },
            "filter": {
              "type": "string",
              "enum": [
                "indexed",
                "named"
              ],
              "description": "Filter type"
            },
            "start": {
              "type": "number",
              "description": "Start index for indexed variables"
            },
            "count": {
              "type": "number",
              "description": "Number of variables to retrieve"
            }
          },
          "required": [
            "sessionId",
            "variablesReference"
          ]
        }
      },
      {
        "name": "debug_evaluate",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "evaluate",
        "displayName": "Evaluate Expression",
        "modelDescription": "Evaluate a Python expression in the current debug context",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-console)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "expression": {
              "type": "string",
              "description": "Expression to evaluate"
            },
            "frameId": {
              "type": "number",
              "description": "Stack frame ID (optional)"
            },
            "context": {
              "type": "string",
              "enum": [
                "watch",
                "repl",
                "hover",
                "clipboard"
              ],
              "description": "Evaluation context"
            }
          },
          "required": [
            "sessionId",
            "expression"
          ]
        }
      },
      {
        "name": "debug_set_variable",
        "tags": [
          "debugging",
          "copilot-debugger"
        ],
        "toolReferenceName": "setVariable",
        "displayName": "Set Variable",
        "modelDescription": "Set the value of a variable",
        "canBeReferencedInPrompt": true,
        "icon": "$(symbol-variable)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string",
              "description": "Debug session ID"
            },
            "variablesReference": {
              "type": "number",
              "description": "Variables reference containing the variable"
            },
            "name": {
              "type": "string",
              "description": "Variable name"
            },
            "value": {
              "type": "string",
              "description": "New value"
            }
          },
          "required": [
            "sessionId",
            "variablesReference",
            "name",
            "value"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "copilotDebugger.showOutput",
        "title": "Copilot Debugger: Show Output"
      }
    ],
    "configuration": {
      "title": "Copilot Debugger",
      "properties": {
        "copilotDebugger.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Log level for Copilot Debugger extension"
        },
        "copilotDebugger.enableLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable file-based debug logging to .vscode/copilot-debugger.log in the workspace"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "test": "npm run compile && mocha dist/*.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.54.0",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0"
  }
}
